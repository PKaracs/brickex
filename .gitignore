# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# content collections (generated at build time)
/.content-collections

# Google service account key (for indexing API)
google-indexing-key.json
.env.local

# Generated image assets (served from Supabase, not local public/)
/public/ideas-generated/
/public/real-estate-full-variations/
/public/real-estate-variations/
/public/shots/
/public/real-estate-presets/
/public/real-estate-sketch/
/public/textures/
/public/real-estate-full/
/public/real-estate-front/
/public/interior-variations/
/public/blog/
/public/tool-previews/
/public/architecture-styles/
/public/interior-styles/
